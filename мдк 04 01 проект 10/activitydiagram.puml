@startuml
start
:Пользователь открывает приложение;
if (Первое использование?) then (да)
  :Выбор базовой валюты;
  :Настройка уведомлений;
else (нет)
endif

repeat
  :Отображение текущих курсов;
  :Ожидание действий пользователя;
  
  if (Конвертация валют?) then (да)
    :Выбор исходной валюты;
    :Выбор целевой валюты;
    :Ввод суммы;
    :Расчет результата;
    :Отображение результата;
  else (нет)
  endif
  
  if (Просмотр истории?) then (да)
    :Выбор периода;
    :Запрос исторических данных;
    :Отображение графика;
  else (нет)
  endif
  
  if (Настройка уведомлений?) then (да)
    :Выбор валютной пары;
    :Установка порогового значения;
    :Сохранение уведомления;
  else (нет)
  endif
  
repeat while (Пользователь не выходит?) is (нет)
:Сохранение настроек;
stop
@enduml